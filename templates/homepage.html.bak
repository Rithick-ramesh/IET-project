{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Amazing India</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <!-- Main CSS -->
    <link rel="stylesheet" href="{% static 'css/homepage.css' %}">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            overflow-x:hidden;
            font-family:Arial, sans-serif;
        }

        /* =========================
           HERO SECTION
        ========================= */

        .starting{
            background:url("{% static 'images/bg.png' %}") center/cover no-repeat;
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            position:relative;
        }

        .starting::before{
            content:"";
            position:absolute;
            inset:0;
            background:rgba(0,0,0,0.5);
        }

        .overlay-card{
            position:relative;
            z-index:2;
            color:white;
            padding:40px;
        }

        .overlay-card h1{
            font-size:70px;
            font-weight:bold;
        }

        .overlay-card p{
            font-size:22px;
            margin-bottom:30px;
        }

        /* =========================
           SEARCH BOX
        ========================= */

        .search-box{
            display:flex;
            justify-content:center;
        }

        .search-form{
            display:flex;
            gap:12px;
            flex-wrap:wrap;
            justify-content:center;
            align-items:center;
        }

        .search-form input{
            width:380px;
            padding:14px 18px;
            border:none;
            border-radius:40px;
            outline:none;
            font-size:16px;
        }

        .search-form button{
            padding:14px 30px;
            border:none;
            border-radius:40px;
            background:#ff9800;
            color:white;
            font-weight:bold;
            transition:0.3s;
        }

        .search-form button:hover{
            background:#e68900;
        }

        /* =========================
           AUTOCOMPLETE
        ========================= */

        .suggestions-list {
            position: absolute;
            top: 105%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 12px;
            z-index: 1050;
            max-height: 280px;
            overflow-y: auto;
            border: 1px solid rgba(0,0,0,0.12);
            text-align: left;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

        .suggestion-item {
            padding: 12px 18px;
            cursor: pointer;
            border-bottom: 1px solid #f2f2f2;
            transition: all 0.2s;
            font-size: 14px;
            color: #333;
            display: flex;
            align-items: center;
        }

        .suggestion-item:last-child {
            border-bottom: none;
        }

        .suggestion-item:hover {
            background: #fff4dd;
        }

        .suggestion-item i {
            font-size: 16px;
            margin-right: 12px;
            color: #ff9800;
        }

        .suggestion-type {
            margin-left: auto;
            font-size: 11px;
            background: #e9ecef;
            color: #495057;
            padding: 3px 8px;
            border-radius: 10px;
            font-weight: bold;
        }

        /* =========================
           SLIDER SECTION
        ========================= */

        .slider-section{
            padding:60px 0;
            background:#f8f9fa;
        }

        .slider-container{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:25px;
            width:90%;
            margin:auto;
        }

        .place-card{
            position:relative;
            overflow:hidden;
            border-radius:20px;
            cursor:pointer;
        }

        .place-card img{
            width:100%;
            height:320px;
            object-fit:cover;
            transition:0.4s;
        }

        .place-card:hover img{
            transform:scale(1.1);
        }

        .overlay{
            position:absolute;
            inset:0;
            background:rgba(0,0,0,0.4);
            display:flex;
            align-items:end;
            padding:20px;
            color:white;
        }

        /* =========================
           SECTION TITLE
        ========================= */

        .section-title{
            text-align:center;
            margin-bottom:40px;
        }

        .section-title h2{
            font-size:42px;
            font-weight:bold;
        }

        /* =========================
           DESTINATION CARD
        ========================= */

        .destination-card{
            border-radius:18px;
            overflow:hidden;
            transition:0.4s;
            background:white;
        }

        .destination-card:hover{
            transform:translateY(-10px);
        }

        .destination-card img{
            width:100%;
            height:250px;
            object-fit:cover;
        }

        .destination-card .card-body{
            padding:20px;
            text-align:center;
        }

        /* =========================
           FESTIVAL SECTION
        ========================= */

        .festival-box{
            position:relative;
            overflow:hidden;
            border-radius:20px;
        }

        .festival-box img{
            width:100%;
            height:350px;
            object-fit:cover;
        }

        .festival-overlay{
            position:absolute;
            inset:0;
            background:rgba(0,0,0,0.4);
            display:flex;
            justify-content:center;
            align-items:center;
            color:white;
            font-size:30px;
            font-weight:bold;
        }

        /* =========================
           COMMUNITY SECTION
        ========================= */

        .community-card{
            background:white;
            padding:30px;
            border-radius:20px;
            transition:0.3s;
            box-shadow:0 5px 15px rgba(0,0,0,0.08);
        }

        .community-card:hover{
            transform:translateY(-8px);
        }

        /* =========================
           FOOTER
        ========================= */

        .footer{
            background:#111;
            color:white;
            padding:60px 0 20px;
        }

        .social-icons a{
            color:white;
            margin-right:15px;
            font-size:22px;
            transition:0.3s;
        }

        .social-icons a:hover{
            color:#ff9800;
        }

        .footer-bottom{
            text-align:center;
            margin-top:30px;
            border-top:1px solid rgba(255,255,255,0.1);
            padding-top:20px;
        }

        /* =========================
           CRAFT SECTION
        ========================= */

        .craft-slider-track {
            display: flex;
            gap: 24px;
            overflow-x: auto;
            scroll-behavior: smooth;
            scrollbar-width: none;
            padding: 15px 5px;
            width: 100%;
        }

        .craft-slider-track::-webkit-scrollbar {
            display: none;
        }

        .craft-card-slide {
            flex: 0 0 280px;
            max-width: 280px;
        }

        .craft-slider-wrapper {
            position: relative;
            padding: 0 10px;
        }

        .slider-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: linear-gradient(135deg, #ff9800, #ff5722);
            border: none;
            border-radius: 50%;
            width: 46px;
            height: 46px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            z-index: 10;
        }

        .prev-arrow {
            left: -20px;
        }

        .next-arrow {
            right: -20px;
        }

        .craft-card {
            border: none;
            border-radius: 20px !important;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            transition: all 0.4s ease;
            background: white;
            cursor: pointer;
        }

        .craft-card:hover {
            transform: translateY(-8px);
        }

        .craft-card img {
            height: 220px;
            object-fit: cover;
            width: 100%;
        }

        .craft-card .state {
            font-size: 13px;
            color: #ff9800;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .craft-card .craft-name {
            font-size: 18px;
            font-weight: 700;
            color: #222;
        }

        @media(max-width:768px){

            .overlay-card h1{
                font-size:45px;
            }

            .search-form input{
                width:100%;
            }

            .slider-arrow{
                display:none;
            }

        }

    </style>
</head>

<body>

<!-- =========================
     NAVBAR
========================= -->

<!-- =========================
     NAVBAR
========================= -->
<nav class="navbar navbar-expand-lg navbar-dark fixed-top"
     style="background: rgba(0, 0, 0, 0.85) !important; backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.15); padding: 15px 0; z-index: 2000; width: 100%;">

    <div class="container">

        <a class="navbar-brand fw-bold text-warning fs-2"
           href="{% url 'home' %}"
           style="letter-spacing: 1px; color: #ffcc00 !important; font-size: 28px !important; text-decoration: none;">
            Amazing India
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end"
             id="navbarNav">

            <ul class="navbar-nav align-items-center gap-3">

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'home' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'about' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        About
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'destination' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Destination
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'ai_planner' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        AI Planner
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'contact' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Contact
                    </a>
                </li>

                {% if user.is_authenticated %}

                <li class="nav-item">
                    <span class="text-white small" style="color: white !important; font-weight: 500;">
                        Hi, {{ user.username }}
                    </span>
                </li>

                <li class="nav-item">
                    <a href="{% url 'logout' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Logout
                    </a>
                </li>

                {% else %}

                <li class="nav-item">
                    <a href="{% url 'login' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Login
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{% url 'signup' %}"
                       class="btn btn-outline-light rounded-pill px-3"
                       style="color: white !important; border: 1px solid white !important; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Sign Up
                    </a>
                </li>

                {% endif %}

            </ul>

        </div>

    </div>

</nav>

<!-- =========================
     HERO SECTION
========================= -->

<section>

    <div class="starting" style="background: url('{% static 'images/bg.png' %}') center/cover no-repeat; min-height: 100vh; display: flex; justify-content: center; align-items: center; position: relative;">

        <!-- Dark Overlay -->
        <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.55); z-index: 1;"></div>

        <div class="overlay-card text-center" style="position: relative; z-index: 2; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 24px; padding: 45px 35px; width: 90%; max-width: 580px; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4); color: white;">

            <h1 class="fw-bold mb-2" style="font-size: 52px; letter-spacing: 1px;">Amazing India</h1>

            <p style="font-size: 20px; color: #f8f9fa; font-weight: 300; margin-bottom: 35px; letter-spacing: 0.5px;">Let's Travel Around India</p>

            <div class="search-box" style="background: transparent; border: none; padding: 0; box-shadow: none;">

                <form class="search-form"
                      id="search-form"
                      action="{% url 'destination' %}"
                      method="GET"
                      style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; align-items: center; width: 100%;">

                    <div class="position-relative" style="flex: 1; min-width: 280px;">

                        <input type="text"
                               id="search-input"
                               name="q"
                               placeholder="Search state or city..."
                               autocomplete="off"
                               required
                               style="width: 100%; padding: 15px 22px; border: none; border-radius: 30px; outline: none; font-size: 16px; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.15); transition: 0.3s;">

                        <div id="suggestions-dropdown"
                             class="suggestions-list d-none"
                             style="position: absolute; top: 110%; left: 0; right: 0; background: white; border-radius: 14px; z-index: 1050; max-height: 280px; overflow-y: auto; border: 1px solid rgba(0,0,0,0.08); text-align: left; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
                        </div>

                    </div>

                    <button type="submit" style="padding: 15px 36px; border: none; border-radius: 30px; background: linear-gradient(135deg, #ff9800, #ff5722); color: white; font-weight: bold; font-size: 16px; transition: 0.3s; box-shadow: 0 4px 15px rgba(255,152,0,0.3); cursor: pointer;">
                        Search
                    </button>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- =========================
     LIVE ALERTS HELP BAR
========================= -->

<section class="py-3" style="background: #fffbf4; border-bottom: 1px solid rgba(255,152,0,0.12); position: relative; z-index: 5;">

    <div class="container text-center">

        <div class="d-flex flex-wrap justify-content-center gap-4 align-items-center">

            <div class="d-flex align-items-center gap-2">
                <span style="display: inline-block; width: 8px; height: 8px; background: #28a745; border-radius: 50%; box-shadow: 0 0 8px #28a745;"></span>
                <span class="fw-bold text-dark" style="font-size: 13px; letter-spacing: 0.3px;">Real-Time Weather Alerts</span>
            </div>

            <div class="d-flex align-items-center gap-2">
                <span style="display: inline-block; width: 8px; height: 8px; background: #28a745; border-radius: 50%; box-shadow: 0 0 8px #28a745;"></span>
                <span class="fw-bold text-dark" style="font-size: 13px; letter-spacing: 0.3px;">Verified Tourist Police Contacts</span>
            </div>

            <div class="d-flex align-items-center gap-2">
                <span style="display: inline-block; width: 8px; height: 8px; background: #28a745; border-radius: 50%; box-shadow: 0 0 8px #28a745;"></span>
                <span class="fw-bold text-dark" style="font-size: 13px; letter-spacing: 0.3px;">Direct Hotel Booking Integrations</span>
            </div>

        </div>

    </div>

</section>

<!-- =========================
     SLIDER SECTION (Top Attractions)
========================= -->

<section class="py-5" style="background: #f8f9fa;">

    <div class="container">

        <div class="section-title text-center mb-5">
            <h2 class="fw-bold" style="font-size: 38px; color: #222; text-transform: uppercase; letter-spacing: 1px;">Top Attractions</h2>
            <p style="color: #ff9800; font-weight: 600; font-size: 16px; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 5px;">Must-Visit Landmarks of India</p>
        </div>

        <div class="slider-container" style="display: flex; gap: 24px; overflow-x: auto; padding: 15px 5px; scrollbar-width: thin; scrollbar-color: #ff9800 #eaeaea;">

            <!-- CARD 1 -->
            <a class="place-card"
               href="{% url 'destination' %}?q=gaya"
               style="display: block; text-decoration: none; position: relative; width: 280px; height: 420px; border-radius: 20px; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 20px rgba(0,0,0,0.06); transition: 0.4s;">
                <img src="{% static 'images/section image1.jpg' %}" alt="Mahabodhi Temple" style="width: 100%; height: 100%; object-fit: cover; transition: 0.4s;">
                <div class="overlay" style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85), transparent); display: flex; align-items: flex-end; padding: 25px; color: white;">
                    <h3 class="fw-bold m-0" style="font-size: 24px; letter-spacing: 0.5px;">Mahabodhi Temple</h3>
                </div>
            </a>

            <!-- CARD 2 -->
            <a class="place-card"
               href="{% url 'goa' %}"
               style="display: block; text-decoration: none; position: relative; width: 280px; height: 420px; border-radius: 20px; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 20px rgba(0,0,0,0.06); transition: 0.4s;">
                <img src="{% static 'images/anuja beach.jpg' %}" alt="Anjuna Beach" style="width: 100%; height: 100%; object-fit: cover; transition: 0.4s;">
                <div class="overlay" style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85), transparent); display: flex; align-items: flex-end; padding: 25px; color: white;">
                    <h3 class="fw-bold m-0" style="font-size: 24px; letter-spacing: 0.5px;">Anjuna Beach</h3>
                </div>
            </a>

            <!-- CARD 3 -->
            <a class="place-card"
               href="{% url 'destination' %}?q=mumbai"
               style="display: block; text-decoration: none; position: relative; width: 280px; height: 420px; border-radius: 20px; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 20px rgba(0,0,0,0.06); transition: 0.4s;">
                <img src="{% static 'images/section image2.webp' %}" alt="Gateway Of India" style="width: 100%; height: 100%; object-fit: cover; transition: 0.4s;">
                <div class="overlay" style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85), transparent); display: flex; align-items: flex-end; padding: 25px; color: white;">
                    <h3 class="fw-bold m-0" style="font-size: 24px; letter-spacing: 0.5px;">Gateway Of India</h3>
                </div>
            </a>

            <!-- CARD 4 -->
            <a class="place-card"
               href="{% url 'destination' %}?q=diu"
               style="display: block; text-decoration: none; position: relative; width: 280px; height: 420px; border-radius: 20px; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 20px rgba(0,0,0,0.06); transition: 0.4s;">
                <img src="{% static 'images/section image3.jpg' %}" alt="Naida Caves" style="width: 100%; height: 100%; object-fit: cover; transition: 0.4s;">
                <div class="overlay" style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85), transparent); display: flex; align-items: flex-end; padding: 25px; color: white;">
                    <h3 class="fw-bold m-0" style="font-size: 24px; letter-spacing: 0.5px;">Naida Caves</h3>
                </div>
            </a>

        </div>

    </div>

</section>

<!-- =========================
     TRADITIONAL CRAFT SECTION
========================= -->

<section class="py-5" style="background: #ffffff; border-top: 1px solid #eaeaea; border-bottom: 1px solid #eaeaea;">

    <div class="container position-relative" style="max-width: 1200px;">

        <div class="section-title text-center mb-5">
            <h2 class="fw-bold" style="font-size: 38px; color: #222; text-transform: uppercase; letter-spacing: 1px;">Traditional Crafts</h2>
            <p style="color: #ff9800; font-weight: 600; font-size: 16px; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 5px;">Of Timeless Indian Heritage</p>
        </div>

        <div class="craft-slider-wrapper" style="position: relative; display: flex; align-items: center; padding: 0 40px;">

            <button class="slider-arrow prev-arrow" id="craft-prev-btn" aria-label="Previous Slide">
                <i class="fa-solid fa-chevron-left"></i>
            </button>

            <div class="craft-slider-track" id="craft-slider-track">

                <!-- CARD 1 -->
                <div class="craft-card-slide">
                    <div class="card craft-card h-100 shadow-sm" onclick="window.location.href='{% url 'destination' %}?q=punjab';">
                        <img src="{% static 'images/traditional section 1.avif' %}" alt="Punjab Phulkari">
                        <div class="card-body" style="background: #fff9f2; padding: 20px;">
                            <div class="state">Punjab</div>
                            <h5 class="craft-name fw-bold mb-0">Phulkari Embroidery</h5>
                        </div>
                    </div>
                </div>

                <!-- CARD 2 -->
                <div class="craft-card-slide">
                    <div class="card craft-card h-100 shadow-sm" onclick="window.location.href='{% url 'destination' %}?q=chhattisgarh';">
                        <img src="{% static 'images/traditional section 2.avif' %}" alt="Chhattisgarh Bastar Dhokra">
                        <div class="card-body" style="background: #fff9f2; padding: 20px;">
                            <div class="state">Chhattisgarh</div>
                            <h5 class="craft-name fw-bold mb-0">Bastar Dhokra Art</h5>
                        </div>
                    </div>
                </div>

                <!-- CARD 3 -->
                <div class="craft-card-slide">
                    <div class="card craft-card h-100 shadow-sm" onclick="window.location.href='{% url 'destination' %}?q=gujarat';">
                        <img src="{% static 'images/traditional section 3.avif' %}" alt="Gujarat Patan Patola">
                        <div class="card-body" style="background: #fff9f2; padding: 20px;">
                            <div class="state">Gujarat</div>
                            <h5 class="craft-name fw-bold mb-0">Patan Patola Silk</h5>
                        </div>
                    </div>
                </div>

                <!-- CARD 4 -->
                <div class="craft-card-slide">
                    <div class="card craft-card h-100 shadow-sm" onclick="window.location.href='{% url 'kashmir' %}';">
                        <img src="{% static 'images/traditional section 4.avif' %}" alt="Kashmir Pashmina">
                        <div class="card-body" style="background: #fff9f2; padding: 20px;">
                            <div class="state">Kashmir</div>
                            <h5 class="craft-name fw-bold mb-0">Pashmina Shawls</h5>
                        </div>
                    </div>
                </div>

                <!-- CARD 5 -->
                <div class="craft-card-slide">
                    <div class="card craft-card h-100 shadow-sm" onclick="window.location.href='{% url 'jaipur' %}';">
