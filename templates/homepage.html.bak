<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- =========================
     SEARCH SCRIPT
========================= -->

<script>

document.addEventListener('DOMContentLoaded', function () {

    let destinations = [];

    try {
        destinations = JSON.parse('{{ catalog_json|escapejs }}');
    } catch (error) {
        console.log("Catalog JSON Error:", error);
    }

    const searchInput = document.getElementById('search-input');
    const searchForm = document.getElementById('search-form');
    const suggestionsDropdown = document.getElementById('suggestions-dropdown');

    searchInput.addEventListener('input', function () {

        const value = this.value.trim().toLowerCase();

        if (!value) {
            suggestionsDropdown.classList.add('d-none');
            return;
        }

        const matches = destinations.filter(item => {

            return (
                item.name.toLowerCase().includes(value) ||
                (item.state &&
                item.state.toLowerCase().includes(value))
            );

        }).slice(0, 8);

        suggestionsDropdown.innerHTML = "";

        if (matches.length > 0) {

            matches.forEach(item => {

                const div = document.createElement('div');

                div.classList.add('suggestion-item');

                const icon =
                    item.type === 'city'
                    ? 'fa-city'
                    : 'fa-location-dot';

                div.innerHTML = `
                    <i class="fa-solid ${icon}"></i>
                    <span>
                        <strong>${item.name}</strong>
                        ${item.state ? ', ' + item.state : ''}
                    </span>
                    <span class="suggestion-type">
                        ${item.type || 'Place'}
                    </span>
                `;

                div.addEventListener('click', function () {

                    searchInput.value = item.name;

                    suggestionsDropdown.classList.add('d-none');

                    searchForm.submit();

                });

                suggestionsDropdown.appendChild(div);

            });

            suggestionsDropdown.classList.remove('d-none');

        } else {

            suggestionsDropdown.classList.add('d-none');

        }

    });

    document.addEventListener('click', function (e) {

        if (
            !searchInput.contains(e.target) &&
            !suggestionsDropdown.contains(e.target)
        ) {
            suggestionsDropdown.classList.add('d-none');
        }

    });

    searchForm.addEventListener('submit', function (e) {

        if (!searchInput.value.trim()) {

            e.preventDefault();

            alert('Please enter a destination');

        }

    });

    // Traditional Craft Slider
    const craftTrack = document.getElementById('craft-slider-track');
    const prevBtn = document.getElementById('craft-prev-btn');
    const nextBtn = document.getElementById('craft-next-btn');

    if (craftTrack && prevBtn && nextBtn) {
        prevBtn.addEventListener('click', function() {
            craftTrack.scrollLeft -= 304; // 280px card width + 24px gap
        });
        nextBtn.addEventListener('click', function() {
            craftTrack.scrollLeft += 304;
        });
    }

});

</script>

</body>
</html>