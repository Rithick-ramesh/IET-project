{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Contact Us - Amazing India</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="{% static 'css/contact us.css' %}">

  <style>
        body {
            padding-top: 85px !important;
        }

    body {
      background: radial-gradient(at 50% 0%, #fffcf5 0%, #f4f6f9 100%) !important;
      font-family: 'Outfit', 'Inter', sans-serif !important;
    }

    /* GLASSMORPHISM FORM OVERRIDES */
    .contact-hero {
      height: 45vh;
      background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1506461883276-594a12b11db3?q=80&w=1800&auto=format&fit=crop') no-repeat center center/cover !important;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      color: white;
    }

    .contact-hero h1 {
      font-size: 68px;
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(135deg, #ffffff 0%, #ffcc00 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 4px 15px rgba(0,0,0,0.4);
    }

    .contact-hero p {
      font-size: 22px;
      margin-top: 15px;
      opacity: 0.9;
    }

    .contact-box {
      background: rgba(255, 255, 255, 0.75) !important;
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.45);
      border-radius: 24px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.08) !important;
      overflow: hidden;
    }

    .contact-info {
      background: linear-gradient(135deg, #e65100 0%, #f57c00 100%) !important;
      padding: 60px 45px !important;
      position: relative;
      overflow: hidden;
    }

    .contact-info h2 {
      font-size: 38px;
      font-weight: 700;
      margin-bottom: 20px;
      letter-spacing: 0.5px;
    }

    .contact-info p {
      font-size: 16px;
      opacity: 0.92;
      margin-bottom: 40px;
      line-height: 1.8;
    }

    .info-item {
      background: rgba(255, 255, 255, 0.1);
      padding: 16px 20px;
      border-radius: 14px;
      margin-bottom: 20px !important;
      border: 1px solid rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(5px);
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
    }

    .info-item:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: translateX(5px);
    }

    .info-item i {
      font-size: 20px !important;
      color: #ffd54f !important;
      margin-right: 18px !important;
    }

    .info-item span {
      font-size: 16px;
      font-weight: 500;
    }

    .contact-form {
      padding: 60px 45px !important;
    }

    .contact-form h2 {
      font-size: 38px;
      font-weight: 700;
      color: #e65100 !important;
      margin-bottom: 30px;
      letter-spacing: 0.5px;
    }

    .form-group-custom {
      position: relative;
      margin-bottom: 22px;
    }

    .form-group-custom i {
      position: absolute;
      left: 20px;
      top: 50%;
      transform: translateY(-50%);
      color: #f57c00;
      font-size: 18px;
      transition: all 0.3s ease;
    }

    .form-group-custom textarea ~ i {
      top: 30px;
    }

    .form-control-custom {
      width: 100%;
      height: 55px;
      padding: 10px 20px 10px 55px;
      border: 1.5px solid rgba(245, 124, 0, 0.15);
      background: rgba(255, 255, 255, 0.9);
      border-radius: 14px;
      font-size: 16px;
      transition: all 0.3s ease;
    }

    .form-control-custom:focus {
      border-color: #f57c00;
      background: #ffffff;
      box-shadow: 0 0 12px rgba(245, 124, 0, 0.15);
      outline: none;
    }

    .form-control-custom:focus ~ i {
      color: #e65100;
    }

    textarea.form-control-custom {
      height: 140px;
      padding-top: 18px;
    }

    .send-btn-custom {
      background: linear-gradient(135deg, #f57c00 0%, #ff9800 100%);
      color: white;
      border: none;
      padding: 15px 40px;
      border-radius: 14px;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 0.5px;
      box-shadow: 0 8px 16px rgba(245, 124, 0, 0.2);
      transition: all 0.3s ease;
      cursor: pointer;
      width: 100%;
    }

    .send-btn-custom:hover {
      background: linear-gradient(135deg, #e65100 0%, #f57c00 100%);
      transform: translateY(-2px);
      box-shadow: 0 12px 20px rgba(245, 124, 0, 0.3);
    }

    /* MAP SECTION Styling */
    .map-section {
      padding: 0 20px 90px;
    }

    .map-container {
      background: white;
      border-radius: 24px;
      padding: 15px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.05);
      overflow: hidden;
    }

    .map-title {
      font-size: 26px;
      font-weight: 700;
      color: #222;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .map-title i {
      color: #f57c00;
    }

    /* Alert Styling */
    .alert-glass {
      background: rgba(76, 175, 80, 0.15) !important;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(76, 175, 80, 0.3) !important;
      color: #2e7d32 !important;
      border-radius: 14px;
      margin-bottom: 25px;
      padding: 15px 20px;
    }
  </style>
</head>

<body>

  <!-- NAVBAR -->
  <!-- =========================
     NAVBAR
========================= -->
<nav class="navbar navbar-expand-lg navbar-dark fixed-top"
     style="background: rgba(0, 0, 0, 0.85) !important; backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.15); padding: 15px 0; z-index: 2000; width: 100%;">

    <div class="container">

        <a class="navbar-brand fw-bold text-warning fs-2"
           href="{% url 'home' %}"
           style="letter-spacing: 1px; color: #ffcc00 !important; font-size: 28px !important; text-decoration: none;">
            Amazing India
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end"
             id="navbarNav">

            <ul class="navbar-nav align-items-center gap-3">

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'home' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'about' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        About
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'destination' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Destination
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'ai_planner' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        AI Planner
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'contact' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Contact
                    </a>
                </li>

                {% if user.is_authenticated %}

                <li class="nav-item">
                    <span class="text-white small" style="color: white !important; font-weight: 500;">
                        Hi, {{ user.username }}
                    </span>
                </li>

                <li class="nav-item">
                    <a href="{% url 'logout' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Logout
                    </a>
                </li>

                {% else %}

                <li class="nav-item">
                    <a href="{% url 'login' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Login
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{% url 'signup' %}"
                       class="btn btn-outline-light rounded-pill px-3"
                       style="color: white !important; border: 1px solid white !important; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Sign Up
                    </a>
                </li>

                {% endif %}

            </ul>

        </div>

    </div>

</nav>

  <!-- HERO SECTION -->
  <section class="contact-hero">
    <div>
      <h1>Contact Us</h1>
      <p>We'd love to hear from you and help plan your journey</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-box">
        <div class="row g-0">

          <!-- LEFT SIDE -->
          <div class="col-lg-5">
            <div class="contact-info">
              <h2>Get In Touch</h2>
              <p>
                Feel free to contact us anytime for travel guidance,
                destination information and trip planning support.
              </p>

              <div class="info-item">
                <i class="fa-solid fa-location-dot"></i>
                <span>25 Tourism Street, Chennai, Tamil Nadu - 600001</span>
              </div>

              <div class="info-item">
                <i class="fa-solid fa-phone"></i>
                <span>+91 98765 43210</span>
              </div>

              <div class="info-item">
                <i class="fa-solid fa-envelope"></i>
                <span>amazingindia@gmail.com</span>
              </div>
            </div>
          </div>

          <!-- RIGHT SIDE -->
          <div class="col-lg-7">
            <div class="contact-form">
              <h2>Send Message</h2>

              <div id="successAlert" class="alert alert-glass d-none animate__animated animate__fadeIn" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> Message sent successfully! We will get back to you shortly.
              </div>

              <form id="contactForm">
                <div class="form-group-custom">
                  <input type="text" id="contactName" class="form-control-custom" placeholder="Your Name" required>
                  <i class="fa-solid fa-user"></i>
                </div>

                <div class="form-group-custom">
                  <input type="email" id="contactEmail" class="form-control-custom" placeholder="Your Email" required>
                  <i class="fa-solid fa-envelope"></i>
                </div>

                <div class="form-group-custom">
                  <input type="text" id="contactSubject" class="form-control-custom" placeholder="Subject" required>
                  <i class="fa-solid fa-pen"></i>
                </div>

                <div class="form-group-custom">
                  <textarea id="contactMessage" class="form-control-custom" placeholder="Write Your Message" required></textarea>
                  <i class="fa-solid fa-message"></i>
                </div>

                <button type="submit" class="send-btn-custom">Send Message</button>
              </form>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- MAP SECTION -->
  <section class="map-section">
    <div class="container">
      <div class="map-container">
        <h3 class="map-title"><i class="fa-solid fa-map-location-dot"></i> Our Location (Chennai Office)</h3>
        <!-- OpenStreetMap Interactive Map -->
        <iframe width="100%" height="450" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" 
                src="https://www.openstreetmap.org/export/embed.html?bbox=80.1900%2C13.0300%2C80.2200%2C13.0600&amp;layer=mapnik&amp;marker=13.0475%2C80.2089" 
                style="border: 0; border-radius: 16px;">
        </iframe>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6 col-md-6 mb-4">
          <h2 class="footer-heading">Amazing India</h2>
          <p class="footer-address">
            25 Tourism Street,<br>
            Chennai, Tamil Nadu,<br>
            India - 600001
          </p>
        </div>

        <div class="col-lg-6 col-md-6 text-md-end text-center">
          <h2 class="connect-heading">Connect With Us</h2>
          <div class="social-icons">
            <a href="#"><i class="fa-solid fa-address-book"></i></a>
            <a href="#"><i class="fa-regular fa-envelope"></i></a>
            <a href="#"><i class="fa-brands fa-instagram"></i></a>
            <a href="#"><i class="fa-brands fa-facebook"></i></a>
            <a href="#"><i class="fa-brands fa-github"></i></a>
          </div>
        </div>
      </div>

      <hr class="footer-line">

      <div class="copyright-text">
        © 2026 All Rights Reserved | Amazing India
      </div>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- JavaScript Form Submission Interceptor -->
  <script>
    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Simulate form submission success
      var successAlert = document.getElementById('successAlert');
      successAlert.classList.remove('d-none');
      
      // Reset form
      document.getElementById('contactForm').reset();
      
      // Scroll to alert
      successAlert.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Auto hide alert after 5 seconds
      setTimeout(function() {
        successAlert.classList.add('d-none');
      }, 5000);
    });
  </script>

</body>
</html>