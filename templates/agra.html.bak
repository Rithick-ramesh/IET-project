{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Agra - Amazing India</title>

  <!-- CSS -->
  <link rel="stylesheet" href="{% static 'css/style.css' %}">

  <!-- Font Awesome -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <style>
        body {
            padding-top: 85px !important;
        }

      /* Hotels Section */
.hotels-section{
    padding: 100px 80px;
    background: #f5f5f5;
}

/* Category */
.hotel-category{
    margin-top: 70px;
}

.category-title{
    font-size: 42px;
    margin-bottom: 35px;
    color: #222;
}

/* Hotel Container */
.hotel-container{
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(320px,1fr));
    gap: 35px;
}

/* Hotel Card */
.hotel-card{
    background: white;
    border-radius: 20px;
    overflow: hidden;

    box-shadow: 0 10px 25px rgba(0,0,0,0.1);

    transition: 0.4s;
}

.hotel-card:hover{
    transform: translateY(-10px);
}

/* Image */
.hotel-card img{
    width: 100%;
    height: 250px;
    object-fit: cover;
}

/* Content */
.hotel-content{
    padding: 25px;
}

.hotel-content h3{
    font-size: 30px;
    margin-bottom: 15px;
}

.hotel-content p{
    font-size: 18px;
    color: #666;
    line-height: 1.8;
    margin-bottom: 20px;
}

/* Hotel Info */
.hotel-info{
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;

    margin-bottom: 20px;

    font-size: 17px;
    color: #444;
}

.hotel-info i{
    color: #ffb300;
    margin-right: 5px;
}

/* Button */
.hotel-content button{
    padding: 14px 28px;
    border: none;
    border-radius: 10px;

    background: linear-gradient(135deg,#ffcc00,#ff9800);

    font-size: 18px;
    font-weight: bold;

    cursor: pointer;

    transition: 0.3s;
}

.hotel-content button:hover{
    transform: scale(1.05);
}
.agra-bg{
    background: url('{% static "images/agraimage8.jpg" %}') no-repeat center center/cover !important;
}

/* Responsive */
@media(max-width:900px){

    .hotels-section{
        padding: 80px 25px;
    }

    .category-title{
        font-size: 34px;
    }

    .hotel-content h3{
        font-size: 24px;
    }

}
    </style>

</head>

<body>

<!-- NAVBAR -->
<!-- =========================
     NAVBAR
========================= -->
<nav class="navbar navbar-expand-lg navbar-dark fixed-top"
     style="background: rgba(0, 0, 0, 0.85) !important; backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.15); padding: 15px 0; z-index: 2000; width: 100%;">

    <div class="container">

        <a class="navbar-brand fw-bold text-warning fs-2"
           href="{% url 'home' %}"
           style="letter-spacing: 1px; color: #ffcc00 !important; font-size: 28px !important; text-decoration: none;">
            Amazing India
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end"
             id="navbarNav">

            <ul class="navbar-nav align-items-center gap-3">

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'home' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'about' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        About
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'destination' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Destination
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'ai_planner' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        AI Planner
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'contact' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Contact
                    </a>
                </li>

                {% if user.is_authenticated %}

                <li class="nav-item">
                    <span class="text-white small" style="color: white !important; font-weight: 500;">
                        Hi, {{ user.username }}
                    </span>
                </li>

                <li class="nav-item">
                    <a href="{% url 'logout' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Logout
                    </a>
                </li>

                {% else %}

                <li class="nav-item">
                    <a href="{% url 'login' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Login
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{% url 'signup' %}"
                       class="btn btn-outline-light rounded-pill px-3"
                       style="color: white !important; border: 1px solid white !important; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Sign Up
                    </a>
                </li>

                {% endif %}

            </ul>

        </div>

    </div>

</nav>

  <!-- Hero Section -->
   <section class="hero agra-bg">
    <div class="overlay"></div>

    <div class="hero-content">

      <h1>Welcome To Agra</h1>

      <p>
        Explore the city of the Taj Mahal,
        rich Mughal architecture, royal heritage,
        and timeless history.
      </p>

     

    </div>

  </section>

<!-- Live Travel Status & Alerts Section -->
<section class="live-alerts-section py-4" style="background: #fff6eb; border-bottom: 1px solid rgba(255, 152, 0, 0.15);">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-3">
      <span class="pulse-indicator"></span>
      <h4 class="fw-bold mb-0 text-dark" style="font-size: 20px; letter-spacing: 0.5px;">Live Travel Status & Alerts</h4>
    </div>
    
    <div class="row g-3">
      <!-- Weather Card -->
      <div class="col-md-3">
        <div class="card h-100 p-3 border-0 shadow-sm alert-status-card">
          <div class="d-flex align-items-center gap-3">
            <div class="alert-icon-box weather-bg"><i class="fa-solid fa-cloud-sun"></i></div>
            <div>
              <h5 class="fw-bold mb-1 small text-muted text-uppercase" style="font-size: 11px;">Local Weather</h5>
              <p class="mb-0 text-dark small font-weight-bold" style="font-size: 13px;">{{ alerts.weather }}</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Crowd Warning Card -->
      <div class="col-md-3">
        <div class="card h-100 p-3 border-0 shadow-sm alert-status-card">
          <div class="d-flex align-items-center gap-3">
            <div class="alert-icon-box crowd-bg"><i class="fa-solid fa-users-line"></i></div>
            <div>
              <h5 class="fw-bold mb-1 small text-muted text-uppercase" style="font-size: 11px;">Crowd Status</h5>
              <p class="mb-0 text-dark small font-weight-bold" style="font-size: 13px;">{{ alerts.crowd }}</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Safety Card -->
      <div class="col-md-3">
        <div class="card h-100 p-3 border-0 shadow-sm alert-status-card">
          <div class="d-flex align-items-center gap-3">
            <div class="alert-icon-box safety-bg"><i class="fa-solid fa-shield-halved"></i></div>
            <div>
              <h5 class="fw-bold mb-1 small text-muted text-uppercase" style="font-size: 11px;">Safety Updates</h5>
              <p class="mb-0 text-dark small font-weight-bold" style="font-size: 13px;">{{ alerts.safety }}</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Emergency Contacts Card -->
      <div class="col-md-3">
        <div class="card h-100 p-3 border-0 shadow-sm alert-status-card">
          <div class="d-flex align-items-center gap-3">
            <div class="alert-icon-box emergency-bg"><i class="fa-solid fa-truck-medical"></i></div>
            <div>
              <h5 class="fw-bold mb-1 small text-muted text-uppercase" style="font-size: 11px;">Emergency Help</h5>
              <p class="mb-1 text-dark small" style="font-size: 12px;"><strong>Hospital:</strong> {{ alerts.hospital }}</p>
              <p class="mb-0 text-dark small" style="font-size: 12px;"><strong>Police:</strong> {{ alerts.police }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Live Alerts CSS overrides -->
<style>
  .pulse-indicator {
    width: 10px;
    height: 10px;
    background-color: #ff9800;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 0 0 rgba(255, 152, 0, 0.7);
    animation: pulse 1.6s infinite;
  }
  
  @keyframes pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(255, 152, 0, 0.7);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 6px rgba(255, 152, 0, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(255, 152, 0, 0);
    }
  }

  .alert-status-card {
    background: white;
    border-radius: 16px;
    transition: all 0.3s ease;
    border-left: 4px solid #ff9800 !important;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
  }

  .alert-status-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(255, 152, 0, 0.1) !important;
  }

  .alert-icon-box {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .weather-bg { background: #e3f2fd; color: #1e88e5; }
  .crowd-bg { background: #fff3e0; color: #fb8c00; }
  .safety-bg { background: #e8f5e9; color: #43a047; }
  .emergency-bg { background: #ffebee; color: #e53935; }
</style>

  <!-- About Section -->
  <section class="about" id="about">

    <div class="about-image">
      <img
        src="{% static 'images/agra image3.webp' %}"
        alt="Agra">
    </div>

    <div class="about-content">

      <span class="section-tag">HISTORICAL WONDER</span>

      <h2>About Agra</h2>

      <p>
        Agra is one of India’s most iconic tourist destinations,
        famous worldwide for the magnificent Taj Mahal,
        one of the Seven Wonders of the World.
      </p>

      <p>
        Located in Uttar Pradesh, Agra showcases the grandeur
        of Mughal architecture through forts, palaces,
        gardens, and ancient monuments.
      </p>

      <div class="info-grid">

        <div class="info-card">
          <i class="fa-solid fa-location-dot"></i>
          <h3>State</h3>
          <p>Uttar Pradesh</p>
        </div>

        <div class="info-card">
          <i class="fa-solid fa-language"></i>
          <h3>Language</h3>
          <p>Hindi</p>
        </div>

        <div class="info-card">
          <i class="fa-solid fa-sun"></i>
          <h3>Best Time</h3>
          <p>October - March</p>
        </div>

        <div class="info-card">
          <i class="fa-solid fa-utensils"></i>
          <h3>Famous Food</h3>
          <p>Petha & Mughlai Cuisine</p>
        </div>

      </div>

    </div>

  </section>

  <!-- Tourist Places -->
  <section class="places" id="places">

    <div class="section-title">
      <h2>Top Tourist Attractions</h2>
      <p>Best places to visit in Agra</p>
    </div>

    <div class="place-container">

      <!-- Card 1 -->
      <div class="place-card">

        <img
          src="{% static 'images/agra image5.jpg' %}"
          alt="Taj Mahal">

        <div class="place-content">
          <h3>Taj Mahal</h3>

          <p>
            The world-famous marble monument built by
            Shah Jahan as a symbol of eternal love.
          </p>
        </div>

      </div>

      <!-- Card 2 -->
      <div class="place-card">

        <img
          src="{% static 'images/agra image6.jpg' %}"
          alt="Agra Fort">

        <div class="place-content">
          <h3>Agra Fort</h3>

          <p>
            A UNESCO World Heritage Site featuring
            stunning Mughal palaces and royal halls.
          </p>
        </div>

      </div>

      <!-- Card 3 -->
      <div class="place-card">

        <img
          src="{% static 'images/agra image2.jpg' %}"
          alt="Fatehpur Sikri">

        <div class="place-content">
          <h3>Fatehpur Sikri</h3>

          <p>
            An ancient Mughal city known for its
            red sandstone architecture and history.
          </p>
        </div>

      </div>

    </div>

  </section>
  <!-- Hotels Section -->
<section class="hotels-section" id="hotels">

    <div class="section-title">
        <h2>Best Hotels In Agra</h2>
        <p>
            Discover luxury, comfort, and affordable stays
            near the Taj Mahal.
        </p>
    </div>

    <!-- Luxury Hotels -->
    <div class="hotel-category">

        <h2 class="category-title">Luxury Hotels</h2>

        <div class="hotel-container">

            <!-- Hotel Card -->
            <div class="hotel-card">

                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=1200&auto=format&fit=crop" alt="Oberoi Amarvilas">

                <div class="hotel-content">

                    <h3>The Oberoi Amarvilas</h3>

                    <p>
                        Experience ultra-luxury rooms with direct
                        Taj Mahal views and world-class hospitality.
                    </p>

                    <div class="hotel-info">
                        <span><i class="fa-solid fa-star"></i> 5 Star</span>
                        <span><i class="fa-solid fa-location-dot"></i> Taj East Gate</span>
                    </div>

                    <button onclick="window.open('https://www.booking.com/searchresults.html?ss=The+Oberoi+Amarvilas+Agra', '_blank')">Book Now</button>

                </div>

            </div>

            <!-- Hotel Card -->
            <div class="hotel-card">

                <img src="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?q=80&w=1200&auto=format&fit=crop" alt="ITC Mughal">

                <div class="hotel-content">

                    <h3>ITC Mughal</h3>

                    <p>
                        Mughal-style luxury resort with spa,
                        gardens, and premium dining experience.
                    </p>

                    <div class="hotel-info">
                        <span><i class="fa-solid fa-star"></i> 5 Star</span>
                        <span><i class="fa-solid fa-location-dot"></i> Fatehabad Road</span>
                    </div>

                    <button onclick="window.open('https://www.booking.com/searchresults.html?ss=ITC+Mughal+Agra', '_blank')">Book Now</button>

                </div>

            </div>

        </div>

    </div>

    <!-- Comfort Hotels -->
    <div class="hotel-category">

        <h2 class="category-title">Comfort Hotels</h2>

        <div class="hotel-container">

            <!-- Hotel Card -->
            <div class="hotel-card">

                <img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?q=80&w=1200&auto=format&fit=crop" alt="Tajview">

                <div class="hotel-content">

                    <h3>Tajview Agra</h3>

                    <p>
                        Comfortable premium stay with beautiful
                        Taj Mahal views and modern facilities.
                    </p>

                    <div class="hotel-info">
                        <span><i class="fa-solid fa-star"></i> 4 Star</span>
                        <span><i class="fa-solid fa-location-dot"></i> Tajganj</span>
                    </div>

                    <button onclick="window.open('https://www.booking.com/searchresults.html?ss=Tajview+Agra+Agra', '_blank')">Book Now</button>

                </div>

            </div>

            <!-- Hotel Card -->
            <div class="hotel-card">

                <img src="https://images.unsplash.com/photo-1445019980597-93fa8acb246c?q=80&w=1200&auto=format&fit=crop" alt="Grand Mercure">

                <div class="hotel-content">

                    <h3>Grand Mercure</h3>

                    <p>
                        Stylish modern hotel offering rooftop pool,
                        comfort, and great hospitality.
                    </p>

                    <div class="hotel-info">
                        <span><i class="fa-solid fa-star"></i> 4 Star</span>
                        <span><i class="fa-solid fa-location-dot"></i> Taj Nagri</span>
                    </div>

                    <button onclick="window.open('https://www.booking.com/searchresults.html?ss=Grand+Mercure+Agra', '_blank')">Book Now</button>

                </div>

            </div>

        </div>

    </div>

    <!-- Affordable Hotels -->
    <div class="hotel-category">

        <h2 class="category-title">Affordable Hotels</h2>

        <div class="hotel-container">

            <!-- Hotel Card -->
            <div class="hotel-card">

                <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?q=80&w=1200&auto=format&fit=crop" alt="Hotel Taj Sojourn">

                <div class="hotel-content">

                    <h3>Hotel Taj Sojourn</h3>

                    <p>
                        Affordable and clean stay near Taj Mahal
                        with excellent hospitality.
                    </p>

                    <div class="hotel-info">
                        <span><i class="fa-solid fa-wallet"></i> Budget</span>
                        <span><i class="fa-solid fa-location-dot"></i> Taj Nagri</span>
                    </div>

                    <button onclick="window.open('https://www.booking.com/searchresults.html?ss=Hotel+Taj+Sojourn+Agra', '_blank')">Book Now</button>

                </div>

            </div>

            <!-- Hotel Card -->
            <div class="hotel-card">

                <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1200&auto=format&fit=crop" alt="Hotel Amar">

                <div class="hotel-content">

                    <h3>Hotel Amar</h3>

                    <p>
                        Budget-friendly hotel with comfortable rooms
                        and excellent tourist location.
                    </p>

                    <div class="hotel-info">
                        <span><i class="fa-solid fa-wallet"></i> Budget</span>
                        <span><i class="fa-solid fa-location-dot"></i> Fatehabad Road</span>
                    </div>

                    <button onclick="window.open('https://www.booking.com/searchresults.html?ss=Hotel+Amar+Agra', '_blank')">Book Now</button>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- Reviews Section -->
{% include 'reviews_section.html' %}

<!-- Footer -->
<footer>

    <h2>Amazing India</h2>

    <p>
      Explore the rich history, architecture,
      and timeless beauty of India.
    </p>

  </footer>

</body>
</html>