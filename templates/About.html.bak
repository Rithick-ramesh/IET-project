{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About - Amazing India</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{% static 'css/about.css' %}">
    <style>
        body {
            padding-top: 85px !important;
        }
    </style>
</head>
<body>

<!-- NAVBAR -->
<!-- =========================
     NAVBAR
========================= -->
<nav class="navbar navbar-expand-lg navbar-dark fixed-top"
     style="background: rgba(0, 0, 0, 0.85) !important; backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.15); padding: 15px 0; z-index: 2000; width: 100%;">

    <div class="container">

        <a class="navbar-brand fw-bold text-warning fs-2"
           href="{% url 'home' %}"
           style="letter-spacing: 1px; color: #ffcc00 !important; font-size: 28px !important; text-decoration: none;">
            Amazing India
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end"
             id="navbarNav">

            <ul class="navbar-nav align-items-center gap-3">

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'home' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'about' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        About
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'destination' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Destination
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'ai_planner' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        AI Planner
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{% url 'contact' %}" style="color: rgba(255, 255, 255, 0.75) !important; font-size: 16px; font-weight: 500; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='#ffcc00'" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'">
                        Contact
                    </a>
                </li>

                {% if user.is_authenticated %}

                <li class="nav-item">
                    <span class="text-white small" style="color: white !important; font-weight: 500;">
                        Hi, {{ user.username }}
                    </span>
                </li>

                <li class="nav-item">
                    <a href="{% url 'logout' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Logout
                    </a>
                </li>

                {% else %}

                <li class="nav-item">
                    <a href="{% url 'login' %}"
                       class="btn btn-warning rounded-pill px-3"
                       style="color: black !important; background-color: #ffcc00 !important; border: none; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Login
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{% url 'signup' %}"
                       class="btn btn-outline-light rounded-pill px-3"
                       style="color: white !important; border: 1px solid white !important; font-weight: bold; font-size: 14px; text-decoration: none;">
                        Sign Up
                    </a>
                </li>

                {% endif %}

            </ul>

        </div>

    </div>

</nav>

   
    <section class="about-hero">
        <div>
            <h1>About India</h1>
            <p>Discover the beauty, culture and heritage of Incredible India</p>
        </div>
    </section>

    <section class="about-section">
        <div class="container">

            <div class="row align-items-center g-5">

                <div class="col-lg-6">
                    <img src="{% static 'images/about bg1.jpg' %}" class="img-fluid about-img" alt="about image">
                </div>

                <div class="col-lg-6">
                    <h2 class="about-title">Welcome To Amazing India</h2>

                    <p class="about-text">
                        India is a land of diversity, culture, traditions, and breathtaking landscapes.
                        From the snowy mountains of the Himalayas to the beautiful beaches of Goa,
                        India offers unforgettable travel experiences for every visitor.
                    </p>

                    <p class="about-text">
                        Amazing India helps travelers explore famous tourist destinations,
                        historical monuments, spiritual places, local foods, and adventure spots
                        across the country. Our goal is to make your journey simple, memorable,
                        and exciting.
                    </p>

                    <button class="btn btn-warning btn-lg mt-3">
                        Explore More
                    </button>
                </div>

            </div>

        </div>
    </section>

 
    <section class="pb-5">
        <div class="container">

            <div class="text-center mb-5">
                <h2 class="fw-bold">Why Choose Us?</h2>
                <p>Experience the best travel services with Amazing India</p>
            </div>

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="feature-box">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <h4>Best Destinations</h4>
                        <p>
                            Explore beautiful tourist places across India with complete travel guidance.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-box">
                        <i class="fa-solid fa-hotel"></i>
                        <h4>Comfort Stay</h4>
                        <p>
                            Find the best hotels and resorts for a comfortable and safe stay.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-box">
                        <i class="fa-solid fa-camera"></i>
                        <h4>Memorable Trips</h4>
                        <p>
                            Create unforgettable memories with amazing travel experiences.
                        </p>
                    </div>
                </div>

            </div>

        </div>
    </section>

    
  <!-- FOOTER SECTION -->

<footer class="footer-section">

    <div class="container">

        <div class="row align-items-center">

            <!-- LEFT CONTENT -->

            <div class="col-lg-6 col-md-6 mb-4">

                <h2 class="footer-logo">Amazing India</h2>

                <p class="footer-text">
                    25 Tourism Street,<br>
                    Chennai, Tamil Nadu,<br>
                    India - 600001
                </p>

            </div>

            <!-- RIGHT CONTENT -->

            <div class="col-lg-6 col-md-6 text-md-end text-center">

                <h2 class="footer-title">Connect With Us</h2>

                <div class="social-icons">

                    <a href="#">
                        <i class="fa-solid fa-address-book"></i>
                    </a>

                    <a href="#">
                        <i class="fa-regular fa-envelope"></i>
                    </a>

                    <a href="#">
                        <i class="fa-brands fa-instagram"></i>
                    </a>

                    <a href="#">
                        <i class="fa-brands fa-facebook"></i>
                    </a>

                    <a href="#">
                        <i class="fa-brands fa-github"></i>
                    </a>

                </div>

            </div>

        </div>

        <!-- LINE -->

        <hr class="footer-line">

        <!-- COPYRIGHT -->

        <div class="text-center copyright-text">

            © 2026 All Rights Reserved | Amazing India

        </div>

    </div>

</footer>